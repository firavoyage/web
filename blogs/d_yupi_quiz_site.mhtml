.pay button { min-width: 184px; box-sizing: border-box; min-height: 48px; d=
isplay: inline-flex; align-items: center; justify-content: center; backgrou=
nd-color: rgb(250, 157, 59); color: rgb(255, 255, 255); font-size: 17px; bo=
rder: none; border-radius: 8px; font-weight: 500; position: relative; outli=
ne: 0px; width: auto; font-family: -apple-system-font, BlinkMacSystemFont, =
"Helvetica Neue", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei UI", =
"Microsoft YaHei", Arial, sans-serif; overflow: hidden; user-select: none; =
white-space: nowrap; }

.pay button .price { font-family: WeChatSansStd-Medium; }

.pay button > div { display: inline-flex; align-items: center; justify-cont=
ent: center; }

.pay button > div .weui-primary-loading { margin-top: 0px; }

.pay .weui-btn_primary { background-color: rgb(250, 157, 59); }

.pay .weui-btn_primary:not(.weui-btn_disabled):active { background-color: r=
gb(250, 157, 59); }

.pay .weui-btn_primary:not(.weui-btn_disabled):active::before { content: ""=
; position: absolute; inset: 0px; background-color: rgba(0, 0, 0, 0.1); }

.pay button:not(.btn_disabled):active::after { content: ""; position: absol=
ute; inset: 0px; background-color: rgba(0, 0, 0, 0.1); }

.pay button.btn_disabled { background-color: rgb(242, 242, 242); color: rgb=
a(0, 0, 0, 0.18); }

.pay_new button { background-color: rgb(7, 193, 96); font-size: 14px; min-h=
eight: 40px; font-weight: 700; }

.pay_new .pay__notice-btn-lg, .pay_new .pay__notice-btn-lg button { font-si=
ze: 17px; }

