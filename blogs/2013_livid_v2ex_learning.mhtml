.page-outline-item:hover { background-color: var(--box-background-color); c=
olor: var(--box-foreground-color); }

ul.nav li a.nav_item:hover { background-color: var(--box-border-color); col=
or: var(--link-hover-color); }

.markdown_body table tr { border-top: 1px solid var(--box-border-color); }

.markdown_body table tr:nth-child(2n) { background-color: var(--box-backgro=
und-alt-color); }

.markdown_body table tr th { color: rgb(255, 255, 255); }

.markdown_body table tr td { border: 1px solid var(--box-border-color); }

.convert_input { background-color: var(--box-background-color); border: 1px=
 solid var(--box-border-color); color: var(--box-foreground-color); }

.item_hot_topic_title { text-shadow: none; }

#ico-select-language { filter: invert(100%); }

.member-activity-bar { background-color: var(--box-background-alt-color); }

.member-activity-start { background-color: var(--link-color); }

.CodeMirror { border: 1px solid var(--box-border-color); }

.image-edit-left { background-color: var(--box-background-alt-color); }

.lang-selector:hover { background-color: var(--box-background-alt-color); }

.light-toggle:hover { text-decoration: none; }

pre { background-color: rgb(29, 31, 33); }

.reply-box-sticky { background-color: var(--box-background-hover-color); }

#no-comments-yet { border: 2px dashed rgba(216, 216, 255, 0.2); color: rgba=
(216, 216, 255, 0.2); }

#site-search { background-image: url("/static/img/search-bg-night.png?v=3D1=
"); }

.settings.block .block-stat:nth-child(2n) { background-color: var(--box-bac=
kground-alt-color); }

.settings.privacy .privacy-settings-form > div:nth-child(2n) { background-c=
olor: var(--box-background-alt-color); }

.game-screenshots { background-color: var(--box-background-alt-color); }

#my-nodes { background-color: var(--box-background-color); }

.fav-node { background-color: var(--box-background-color); }

.fav-node:hover { background-color: var(--box-background-alt-color); }

.image-grid a.image-grid-item { background-color: transparent; }

.image-grid a.image-grid-item:hover { background-color: var(--box-backgroun=
d-alt-color); }

.image-view { background-color: transparent; }

.image-view:hover { background-color: var(--box-background-alt-color); }

.image-edit .image-edit-info { background-color: var(--box-background-alt-c=
olor); }

#workspace { border-bottom: 1px solid rgb(34, 48, 63); }

#syntax-selector label { color: rgb(0, 0, 0); }
