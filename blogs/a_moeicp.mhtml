Content-Type: text/css
Content-Transfer-Encoding: quoted-printable
Content-Location: https://icp.gov.moe/css/style.css

@charset "utf-8";

* { margin: 0px; padding: 0px; box-sizing: border-box; }

input, textarea, button { outline: none; background-color: transparent; bor=
der: 0px; }

body { font-family: "zcool kuaile", cursive; display: flex; -webkit-box-ali=
gn: center; align-items: center; -webkit-box-pack: center; justify-content:=
 center; }

.cntr { display: table; width: 100%; height: 100%; }

.cntr .cntr-innr { display: table-cell; text-align: center; vertical-align:=
 middle; }

h1 { text-align: center; margin-bottom: 10px; }

p { margin-top: 10px; }

i { margin-top: 10px; color: rgb(240, 128, 128); }

.page { min-height: 100vh; width: 95%; display: flex; -webkit-box-pack: cen=
ter; justify-content: center; -webkit-box-align: center; align-items: cente=
r; font-weight: lighter; }

.login-input-pink { width: 220px; height: 20px; border-width: 1px; border-r=
adius: 3px; border-style: solid; border-color: pink; background: rgb(255, 2=
55, 255); outline: none; font-family: "Microsoft YaHei"; color: rgb(0, 0, 0=
); font-size: 14px; }

.login-input-pink:hover { background: rgb(255, 255, 255); border-color: rgb=
(239, 2, 125); }

.login-button { width: 160px; height: 20px; border-width: 0px; border-radiu=
s: 3px; background: rgb(216, 135, 11); cursor: pointer; outline: none; colo=
r: rgb(255, 255, 255); font-size: 14px; }

.login-button:hover { background: rgb(255, 153, 0); }

.login-buttongm { width: 80px; height: 20px; border-width: 0px; border-radi=
us: 3px; background: rgb(216, 135, 11); cursor: pointer; outline: none; col=
or: rgb(255, 255, 255); font-size: 14px; }

.login-buttongm:hover { background: rgb(255, 153, 0); }

.login-input-pink1 { width: 160px; height: 20px; border-width: 1px; border-=
radius: 3px; border-style: solid; border-color: pink; background: rgb(255, =
255, 255); outline: none; font-family: "Microsoft YaHei"; color: rgb(0, 0, =
0); font-size: 14px; }

.login-input-pink1:hover { background: rgb(255, 255, 255); border-color: rg=
b(239, 2, 125); }

.bg { position: fixed; inset: 0px; background-image: url("https://icp.gov.m=
oe/images/yue.jpg"); background-repeat: no-repeat; background-position: cen=
ter center; background-size: cover; background-attachment: fixed; }

.container { position: relative; max-width: 800px; width: 95%; padding: 45p=
x 65px; border-radius: 10px; color: rgb(255, 255, 255); overflow: hidden; }

.container.result { background: rgba(120, 129, 147, 0.3); box-shadow: rgb(5=
1, 51, 51) 0px 0px 10px 0px; backdrop-filter: blur(10px); }

h1.title { text-align: center; margin-bottom: 30px; }

.search-form { text-align: center; font-size: 16px; }

.search-form input { border: 1px solid rgb(225, 225, 225); border-radius: 5=
0px; width: 100%; line-height: 1; font-size: 16px; padding: 15px 30px; colo=
r: rgb(255, 255, 255); text-align: center; margin-bottom: 30px; }

.search-form input::-webkit-input-placeholder { color: rgb(245, 245, 245); =
}

.search-form .search-submit { padding: 15px 60px; border: 0px; border-radiu=
s: 50px; color: rgb(255, 255, 255); font-size: 16px; cursor: pointer; line-=
height: 1; transition: all 0.3s ease 0s; background: linear-gradient(90deg,=
 rgb(156, 81, 255), rgb(129, 107, 255)); }

.info { border: 1px solid rgb(225, 225, 225); border-radius: 10px; }

.info .info-item { padding: 0px; display: flex; }

.info .info-item ~ .info-item { border-top: 1px solid rgb(225, 225, 225); }

.info .info-item .lable { border-right: 1px solid rgb(225, 225, 225); width=
: 120px; padding: 12px 20px; text-align-last: justify; }

.info .info-item .value { flex: 1 1 0%; padding: 12px 20px; }

.div_foot { position: fixed; bottom: 20px; left: 0px; text-align: center; w=
idth: 100%; font-size: 16px; letter-spacing: 1px; }

@media (max-width: 820px) {
  .container { padding: 20px; }
}
