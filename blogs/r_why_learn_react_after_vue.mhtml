  #nodes { width: 200px; }
}

#my-nodes { display: grid; padding: 0px; position: relative; grid: none / 1=
fr 1fr 1fr 1fr; place-items: center stretch; text-align: center; background=
-color: var(--box-background-alt-color); }

.fav-node { display: block; font-size: 14px; background-color: var(--box-ba=
ckground-alt-color); width: 100%; height: 120px; padding: 20px 0px; margin:=
 0px auto; transition: box-shadow 0.2s ease 0s; text-decoration: none; bord=
er-radius: var(--box-border-radius); }

.fav-node * { display: block; margin: 0px auto; }

.fav-node > .fav-node-name { margin: 10px auto 5px; }

.fav-node:hover { background-color: rgb(240, 240, 240); box-shadow: rgba(0,=
 0, 0, 0.08) 0px 5px 20px inset; cursor: pointer; text-decoration: none; }

.no-fav-nodes { display: flex; padding: 20px; justify-content: space-evenly=
; align-items: center; }

.no-fav-nodes > .info { margin: 0px 0px 0px 20px; text-align: center; }

.no-fav-nodes > .info > * { display: block; margin: var(--box-padding) 0; }

#workspace { text-align: left; border-bottom: 1px solid rgb(226, 226, 226);=
 font-size: 14px; line-height: 120%; min-height: 300px; }

#preview { box-sizing: border-box; min-height: 301px; }

#syntax-selector { display: inline-flex; align-items: center; }

#syntax-label { font-size: 14px; line-height: 100%; vertical-align: bottom;=
 margin-right: 10px; }

.avatar-list { display: flex; flex-wrap: wrap; gap: 10px; align-items: cent=
er; margin-bottom: 20px; margin-top: 10px; }

.status { min-height: 48px; padding: 10px; text-align: left; }

.status_avatar { display: block; float: left; width: 48px; height: 48px; }

.status_avatar .avatar { width: 48px; height: 48px; }

.status_main { margin: 0px 0px 0px 58px; font-size: 14px; text-align: left;=
 }

.status_author { font-weight: 700; display: inline-block; }

.status_time { display: inline-block; font-size: 11px; }

.status_dot { font-size: 12px; }

.status_content { line-height: 160%; word-break: break-word; }

.status_ops { font-size: 11px; line-height: 11px; text-align: right; margin=
-top: 5px; visibility: visible; }

.status:hover .status_ops { visibility: visible; }

.upload-button { color: var(--link-color); stroke: var(--link-color); }

.upload-button:hover { color: var(--link-hover-color); stroke: var(--link-h=
