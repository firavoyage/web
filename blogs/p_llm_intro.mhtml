.byte-affix { z-index: 11; }

.byte-alert { position: relative; padding: 14px; border-radius: 2px; color:=
 rgb(40, 47, 56); font-size: 14px; line-height: 1.5; margin-bottom: 10px; }

.byte-alert--icon { padding-left: 42px; }

.byte-alert--close { padding-right: 48px; }

.byte-alert--info { border: 1px solid rgb(51, 112, 255); background-color: =
rgb(240, 247, 255); }

.byte-alert--info .byte-alert__icon { color: rgb(51, 112, 255); }

.byte-alert--success { border: 1px solid rgb(15, 191, 96); background-color=
: rgb(230, 255, 237); }

.byte-alert--success .byte-alert__icon { color: rgb(15, 191, 96); }

.byte-alert--loading, .byte-alert--warning { border: 1px solid rgb(245, 133=
, 5); background-color: rgb(255, 247, 230); }

.byte-alert--loading .byte-alert__icon, .byte-alert--warning .byte-alert__i=
con { color: rgb(245, 133, 5); }

.byte-alert--error { border: 1px solid rgb(238, 77, 56); background-color: =
rgb(255, 244, 240); }

.byte-alert--error .byte-alert__icon { color: rgb(238, 77, 56); }

.byte-alert--banner { border: 0px; border-radius: 0px; }

.byte-alert__icon { font-size: 16px; top: 11px; left: 14px; position: absol=
ute; }

.byte-alert__title { font-weight: 600; }

.byte-alert__content { display: block; }

.byte-alert__close { cursor: pointer; font-size: 16px; color: rgb(147, 154,=
 163); transition: color 0.2s ease 0s; position: absolute; overflow: hidden=
; top: 18px; right: 14px; line-height: 1; }

.byte-alert__close:hover { color: rgb(51, 112, 255); }

.byte-alert__close .byte-icon { vertical-align: top; }

.byte-alert--custom-close .byte-alert__close { font-size: 14px; color: rgb(=
51, 112, 255); }

.byte-anchor { position: relative; }

.byte-anchor__inner { overflow: hidden; }

.byte-anchor__border { position: absolute; top: 0px; left: 0px; height: 100=
%; width: 1px; background-color: rgb(230, 232, 235); }

.byte-anchor__slider { display: none; position: absolute; left: 1px; width:=
 2px; height: 16px; background-color: rgb(51, 112, 255); transform: transla=
te(-50%); transition: top 0.3s linear 0s; }

.byte-anchor-link { margin-left: 12px; }

.byte-anchor-link__title { display: block; color: rgb(147, 154, 163); line-=
height: 22px; margin-bottom: 8px; overflow: hidden; text-overflow: ellipsis=
; white-space: nowrap; }

.byte-anchor-link--active > .byte-anchor-link__title { color: rgb(40, 47, 5=
6); font-weight: 600; }

.byte-anchor-link__title:hover { color: rgb(40, 47, 56); }

.byte-anchor-link:nth-child(2) { margin-top: 8px; }

.byte-anchor-link:last-child { margin-bottom: 8px; }

