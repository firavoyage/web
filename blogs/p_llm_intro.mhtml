lign: middle; background-color: rgb(194, 198, 204); border-radius: 50%; tex=
t-align: center; line-height: 1.5; color: rgb(255, 255, 255); font-size: 12=
px; overflow: hidden; }

.byte-avatar--square { border-radius: 2px; }

