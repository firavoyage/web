ion=3D"w" value=3D"#include <iostream>
#include <fruit/fruit.h>

using fruit::Component;
using fruit::Injector;

class Writer
{
public:
    virtual void write(std::string str) =3D 0;
};

class StdoutWriter : public Writer
{
public:
    // Like &quot;StdoutWriter() =3D default;&quot; but also marks this con=
structor as the
    // one to use for injection.
    INJECT(StdoutWriter()) =3D default;

    virtual void write(std::string str) override
    {
        std::cout << str;
    }
};

class Greeter
{
public:
    virtual void greet() =3D 0;
};

class GreeterImpl : public Greeter
{
private:
    Writer* writer;

public:
    // Like &quot;GreeterImpl(Writer* writer) {...}&quot;
    // but also marks this constructor as the one to use for injection.
    INJECT(GreeterImpl(Writer* writer))
        : writer(writer)
    {
    }

    virtual void greet() override
    {
        writer->write(&quot;Hello world!\n&quot;);
    }
};

Component<Greeter> getGreeterComponent()
{
    return fruit::createComponent()
        .bind<Writer, StdoutWriter>()
        .bind<Greeter, GreeterImpl>();
}

int main()
{
    Injector<Greeter> injector(getGreeterComponent());
    Greeter* greeter =3D injector.get<Greeter*>();
    greeter->greet();
    return 0;
