    short          http_port =3D 8080;
    char*          http_addr =3D &quot;127.0.0.1&quot;;
    struct evhttp* http_server =3D NULL;

    event_init();
    http_server =3D evhttp_start(http_addr, http_port);
    evhttp_set_gencb(http_server, generic_request_handler, NULL);

    fprintf(stderr, &quot;Server started on port %d\n&quot;, http_port);
